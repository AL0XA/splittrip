# Скопируй в .env и заполни своими значениями
# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Username бота без @ (например, my_split_bot). Нужен для инвайт-ссылок.
BOT_USERNAME=my_split_bot

# Публичный HTTPS-URL, где хостится фронтенд (Mini App).
# Для локальной разработки используй туннель (ngrok / cloudflared), см. README.
WEBAPP_URL=https://example.com

# Хост и порт FastAPI-сервера
HOST=0.0.0.0
PORT=8000
